<section class="slide slide-cover">
  {% if eyebrow %}<div class="eyebrow">{{ eyebrow }}</div>{% endif %}
  <div class="cover-layout">
    <div>
      <h1 class="cover-title">{{ title }}</h1>
      {% if subtitle %}<p class="cover-subtitle">{{ subtitle }}</p>{% endif %}
      {% if heroText %}<p class="body-text" style="margin-top:20px; max-width:540px;">{{ heroText }}</p>{% endif %}
    </div>
    <div class="hero-frame">
      {% if visual and visual.src %}
        <img src="{{ visual.src }}" alt="{{ visual.alt or title }}">
      {% else %}
        <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:var(--text-soft); font-size:18px;">No hero image</div>
      {% endif %}
    </div>
  </div>
  {% if notes %}<div class="footnote">{{ notes }}</div>{% endif %}
</section>
